{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "cds watch (dev)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/cds",
      "args": ["watch"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "cds serve (prod)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
