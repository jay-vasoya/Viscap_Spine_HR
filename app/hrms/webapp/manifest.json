{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.viscap.hrms",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "VISCAP HRMS",
    "description": "HR Self Service Portal",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "hrmsService": {
        "uri": "/odata/v4/hrms/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
      "viewName": "com.viscap.hrms.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.m":          {},
        "sap.ui.core":    {},
        "sap.f":          {},
        "sap.ui.layout":  {},
        "sap.ui.unified": {},
        "sap.uxap":       {},
        "sap.tnt":        {}
      }
    },
    "contentDensities": { "compact": true, "cozy": true },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.viscap.hrms.i18n.i18n",
          "supportedLocales": [""],
          "fallbackLocale": ""
        }
      },
      "hrms": {
        "dataSource": "hrmsService",
        "preload": true,
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.viscap.hrms.view",
        "controlId": "idAppControl",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        { "pattern": "login",      "name": "login",      "target": "login"      },
        { "pattern": "",           "name": "dashboard",  "target": "dashboard"  },
        { "pattern": "attendance", "name": "attendance", "target": "attendance" },
        { "pattern": "leave",      "name": "leave",      "target": "leave"      },
        { "pattern": "salary",     "name": "salary",     "target": "salary"     },
        { "pattern": "profile",    "name": "profile",    "target": "profile"    },
        { "pattern": "employment", "name": "employment", "target": "employment" },
        { "pattern": "contact",    "name": "contact",    "target": "contact"    },
        { "pattern": "personal",   "name": "personal",   "target": "personal"   },
        { "pattern": "edit-profile", "name": "edit-profile", "target": "edit-profile" },
        { "pattern": "edit-contact", "name": "edit-contact", "target": "edit-contact" },
        { "pattern": "edit-personal", "name": "edit-personal", "target": "edit-personal" },
        { "pattern": "edit-immigration", "name": "edit-immigration", "target": "edit-immigration" },
        { "pattern": "edit-visa", "name": "edit-visa", "target": "edit-visa" },
        { "pattern": "edit-driving-license", "name": "edit-driving-license", "target": "edit-driving-license" },
        { "pattern": "edit-family", "name": "edit-family", "target": "edit-family" },
        { "pattern": "edit-skills", "name": "edit-skills", "target": "edit-skills" },
        { "pattern": "edit-nominee", "name": "edit-nominee", "target": "edit-nominee" },
        { "pattern": "edit-languages", "name": "edit-languages", "target": "edit-languages" },
        { "pattern": "edit-qualification", "name": "edit-qualification", "target": "edit-qualification" },
        { "pattern": "edit-previous-experience", "name": "edit-previous-experience", "target": "edit-previous-experience" },
        { "pattern": "salary-ctc", "name": "salary-ctc", "target": "salary-ctc" },
        { "pattern": "salary-payslip", "name": "salary-payslip", "target": "salary-payslip" },
        { "pattern": "salary-monthly-report", "name": "salary-monthly-report", "target": "salary-monthly-report" },
        { "pattern": "view-statutory", "name": "view-statutory", "target": "view-statutory" },
        { "pattern": "view-family", "name": "view-family", "target": "view-family" },
        { "pattern": "view-nominee", "name": "view-nominee", "target": "view-nominee" },
        { "pattern": "view-immigration", "name": "view-immigration", "target": "view-immigration" },
        { "pattern": "view-driving-license", "name": "view-driving-license", "target": "view-driving-license" },
        { "pattern": "view-skills", "name": "view-skills", "target": "view-skills" },
        { "pattern": "view-languages", "name": "view-languages", "target": "view-languages" },
        { "pattern": "view-qualification", "name": "view-qualification", "target": "view-qualification" },
        { "pattern": "view-social-details", "name": "view-social-details", "target": "view-social-details" },
        { "pattern": "view-assets", "name": "view-assets", "target": "view-assets" },
        { "pattern": "view-policy", "name": "view-policy", "target": "view-policy" },
        { "pattern": "change-password", "name": "change-password", "target": "change-password" }
      ],
      "targets": {
        "login":      { "viewName": "Login",      "viewLevel": 0 },
        "dashboard":  { "viewName": "Dashboard",  "viewLevel": 1 },
        "attendance": { "viewName": "Attendance", "viewLevel": 1 },
        "leave":      { "viewName": "Leave",      "viewLevel": 1 },
        "salary":     { "viewName": "Salary",     "viewLevel": 1 },
        "profile":    { "viewName": "Profile",    "viewLevel": 1 },
        "employment": { "viewName": "Employment", "viewLevel": 1 },
        "contact":    { "viewName": "Contact",    "viewLevel": 1 },
        "personal":   { "viewName": "Personal",   "viewLevel": 1 },
        "edit-profile": { "viewName": "EditProfile", "viewLevel": 1 },
        "edit-contact": { "viewName": "EditContact", "viewLevel": 1 },
        "edit-personal": { "viewName": "EditPersonal", "viewLevel": 1 },
        "edit-immigration": { "viewName": "EditImmigration", "viewLevel": 1 },
        "edit-visa": { "viewName": "EditVisa", "viewLevel": 1 },
        "edit-driving-license": { "viewName": "EditDrivingLicense", "viewLevel": 1 },
        "edit-family": { "viewName": "EditFamily", "viewLevel": 1 },
        "edit-skills": { "viewName": "EditSkills", "viewLevel": 1 },
        "edit-nominee": { "viewName": "EditNominee", "viewLevel": 1 },
        "edit-languages": { "viewName": "EditLanguages", "viewLevel": 1 },
        "edit-qualification": { "viewName": "EditQualification", "viewLevel": 1 },
        "edit-previous-experience": { "viewName": "EditPreviousExperience", "viewLevel": 1 },
        "salary-ctc": { "viewName": "SalaryCTC", "viewLevel": 1 },
        "salary-payslip": { "viewName": "SalaryPayslip", "viewLevel": 1 },
        "salary-monthly-report": { "viewName": "SalaryMonthlyReport", "viewLevel": 1 },
        "view-statutory": { "viewName": "ViewStatutory", "viewLevel": 1 },
        "view-family": { "viewName": "ViewFamily", "viewLevel": 1 },
        "view-nominee": { "viewName": "ViewNominee", "viewLevel": 1 },
        "view-immigration": { "viewName": "ViewImmigration", "viewLevel": 1 },
        "view-driving-license": { "viewName": "ViewDrivingLicense", "viewLevel": 1 },
        "view-skills": { "viewName": "ViewSkills", "viewLevel": 1 },
        "view-languages": { "viewName": "ViewLanguages", "viewLevel": 1 },
        "view-qualification": { "viewName": "ViewQualification", "viewLevel": 1 },
        "view-social-details": { "viewName": "ViewSocialDetails", "viewLevel": 1 },
        "view-assets": { "viewName": "ViewAssets", "viewLevel": 1 },
        "view-policy": { "viewName": "ViewPolicy", "viewLevel": 1 },
        "change-password": { "viewName": "ChangePassword", "viewLevel": 1 }
      }
    }
  }
}
