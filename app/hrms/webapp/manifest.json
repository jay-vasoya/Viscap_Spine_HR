{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.viscap.hrms",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "VISCAP HRMS",
    "description": "HR Self Service Portal",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "hrmsService": {
        "uri": "/odata/v4/hrms/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
      "viewName": "com.viscap.hrms.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.m":          {},
        "sap.ui.core":    {},
        "sap.f":          {},
        "sap.ui.layout":  {},
        "sap.ui.unified": {},
        "sap.uxap":       {},
        "sap.tnt":        {}
      }
    },
    "contentDensities": { "compact": true, "cozy": true },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.viscap.hrms.i18n.i18n",
          "supportedLocales": [""],
          "fallbackLocale": ""
        }
      },
      "hrms": {
        "dataSource": "hrmsService",
        "preload": true,
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.viscap.hrms.view",
        "controlId": "idAppControl",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        { "pattern": "login",      "name": "login",      "target": "login"      },
        { "pattern": "",           "name": "dashboard",  "target": "dashboard"  },
        { "pattern": "attendance", "name": "attendance", "target": "attendance" },
        { "pattern": "leave",      "name": "leave",      "target": "leave"      },
        { "pattern": "salary",     "name": "salary",     "target": "salary"     },
        { "pattern": "profile",    "name": "profile",    "target": "profile"    },
        { "pattern": "employment", "name": "employment", "target": "employment" },
        { "pattern": "contact",    "name": "contact",    "target": "contact"    }
      ],
      "targets": {
        "login":      { "viewName": "Login",      "viewLevel": 0 },
        "dashboard":  { "viewName": "Dashboard",  "viewLevel": 1 },
        "attendance": { "viewName": "Attendance", "viewLevel": 1 },
        "leave":      { "viewName": "Leave",      "viewLevel": 1 },
        "salary":     { "viewName": "Salary",     "viewLevel": 1 },
        "profile":    { "viewName": "Profile",    "viewLevel": 1 },
        "employment": { "viewName": "Employment", "viewLevel": 1 },
        "contact":    { "viewName": "Contact",    "viewLevel": 1 }
      }
    }
  }
}
