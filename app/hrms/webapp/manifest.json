{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.viscap.hrms",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "VISCAP HRMS",
    "description": "HR Self Service Portal",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "hrmsService": {
        "uri": "/odata/v4/hrms/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
      "viewName": "com.viscap.hrms.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {},
        "sap.ui.unified": {},
        "sap.uxap": {},
        "sap.tnt": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.viscap.hrms.i18n.i18n",
          "supportedLocales": [""],
          "fallbackLocale": ""
        }
      },
      "hrms": {
        "dataSource": "hrmsService",
        "preload": true,
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.viscap.hrms.view",
        "controlId": "idAppControl",
        "controlAggregation": "pages",
        "async": true,
        "transition": "slide"
      },
      "routes": [
        {
          "pattern": "login",
          "name": "login",
          "target": "login"
        },
        {
          "pattern": "",
          "name": "dashboard",
          "target": "dashboard"
        },
        {
          "pattern": "attendance",
          "name": "attendance",
          "target": "attendance"
        },
        {
          "pattern": "leaveMenu",
          "name": "leaveMenu",
          "target": "leaveMenu"
        },
        {
          "pattern": "leave",
          "name": "leave",
          "target": "leave"
        },
        {
          "pattern": "leaveMyInfo",
          "name": "leaveMyInfo",
          "target": "leaveMyInfo"
        },
        {
          "pattern": "leavePlanner",
          "name": "leavePlanner",
          "target": "leavePlanner"
        },
        {
          "pattern": "outdoorDuty",
          "name": "outdoorDuty",
          "target": "outdoorDuty"
        },
        {
          "pattern": "compOff",
          "name": "compOff",
          "target": "compOff"
        },
        {
          "pattern": "salary",
          "name": "salary",
          "target": "salary"
        },
        {
          "pattern": "profile",
          "name": "profile",
          "target": "profile"
        },
        {
          "pattern": "employment",
          "name": "employment",
          "target": "employment"
        },
        {
          "pattern": "contact",
          "name": "contact",
          "target": "contact"
        }
      ],
      "targets": {
        "login": {
          "viewName": "Login",
          "viewLevel": 0,
          "transition": "fade"
        },
        "dashboard": {
          "viewName": "Dashboard",
          "viewLevel": 1,
          "transition": "slide"
        },
        "attendance": {
          "viewName": "Attendance",
          "viewLevel": 2,
          "transition": "slide"
        },
        "leaveMenu": {
          "viewName": "LeaveMenu",
          "viewLevel": 2,
          "transition": "slide"
        },
        "leave": {
          "viewName": "Leave",
          "viewLevel": 3,
          "transition": "slide"
        },
        "leaveMyInfo": {
          "viewName": "LeaveMyInfo",
          "viewLevel": 3,
          "transition": "slide"
        },
        "leavePlanner": {
          "viewName": "LeavePlanner",
          "viewLevel": 3,
          "transition": "slide"
        },
        "outdoorDuty": {
          "viewName": "OutdoorDuty",
          "viewLevel": 3,
          "transition": "slide"
        },
        "compOff": {
          "viewName": "CompOff",
          "viewLevel": 3,
          "transition": "slide"
        },
        "salary": {
          "viewName": "Salary",
          "viewLevel": 2,
          "transition": "slide"
        },
        "profile": {
          "viewName": "Profile",
          "viewLevel": 2,
          "transition": "slide"
        },
        "employment": {
          "viewName": "Employment",
          "viewLevel": 2,
          "transition": "slide"
        },
        "contact": {
          "viewName": "Contact",
          "viewLevel": 2,
          "transition": "slide"
        }
      }
    }
  }
}