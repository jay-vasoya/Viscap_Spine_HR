<mvc:View
    controllerName="com.viscap.hrms.controller.SalaryMonthlyReport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page title="Salary > Monthly Report" showNavButton="true" navButtonPress="onNavBack">
        <headerContent>
            <Button icon="sap-icon://print" />
        </headerContent>
        <content>
            <VBox class="sapUiMediumMargin">
                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                    <Label text="For The Period" class="sapUiSmallMarginEnd" />
                    <Select width="200px" class="sapUiTinyMarginEnd">
                        <items>
                            <core:Item text="--Select Period--" key="" />
                        </items>
                    </Select>
                    <Button text="Refresh" type="Emphasized" press="onRefresh" />
                </HBox>
                
                <Table noDataText="No details available" class="sapUiMediumMarginTop">
                    <columns>
                        <Column><Text text="Components" /></Column>
                        <Column hAlign="End"><Text text="Earnings" /></Column>
                        <Column hAlign="End"><Text text="Deductions" /></Column>
                    </columns>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
