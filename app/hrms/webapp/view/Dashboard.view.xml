<mvc:View
    controllerName="com.viscap.hrms.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:grid="sap.ui.layout.cssgrid"
    displayBlock="true">

    <Page id="dashboardPage" title="Self Service" backgroundDesign="List">
        <headerContent>
            <SearchField width="300px" placeholder="Search...." class="sapUiSmallMarginEnd" />
        </headerContent>
        <content>
            <VBox class="sapUiMediumMargin">
                <layout:Grid defaultSpan="XL4 L4 M6 S12">
                    <!-- View Category -->
                    <VBox class="hrmsCategoryBox">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://unhide" size="2rem" color="#1a2a6c" xmlns:core="sap.ui.core" />
                            <Title text="View" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <VBox class="hrmsLinkList">
                            <Link text="Employment" press="onNavEmployment" />
                            <Link text="Contact" press="onNavContact" />
                            <Link text="Personal" press="onNavPersonal" />
                             <Link text="Statutory" press="onNavViewStatutory" />
                             <Link text="Family" />
                             <Link text="Nominee" />
                             <Link text="Immigration" press="onNavViewImmigration" />
                             <Link text="Driving Licenses" press="onNavViewDrivingLicense" />
                             <Link text="Skills" press="onNavViewSkills" />
                             <Link text="Languages" press="onNavViewLanguages" />
                             <Link text="Qualifications" press="onNavViewQualification" />
                             <Link text="Social Details" press="onNavViewSocialDetails" />
                             <Link text="Assets List" press="onNavViewAssets" />
                             <Link text="Previous Experience" press="onNavEditPreviousExperience" />
                             <Link text="Policy" press="onNavViewPolicy" />
                        </VBox>
                    </VBox>

                    <!-- Edit Category -->
                    <VBox class="hrmsCategoryBox">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://edit" size="2rem" color="#b21f1f" xmlns:core="sap.ui.core" />
                            <Title text="Edit" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <VBox class="hrmsLinkList">
                            <Link text="Profile" press="onNavEditProfile" />
                            <Link text="Contact" press="onNavEditContact" />
                            <Link text="Personal" press="onNavEditPersonal" />
                            <Link text="Immigration" press="onNavEditImmigration" />
                            <Link text="Visa Details" press="onNavEditVisa" />
                            <Link text="Driving License" press="onNavEditDrivingLicense" />
                            <Link text="Family" press="onNavEditFamily" />
                            <Link text="Nominee" press="onNavEditNominee" />
                            <Link text="Skills" press="onNavEditSkills" />
                            <Link text="Languages" press="onNavEditLanguages" />
                            <Link text="Qualification" press="onNavEditQualification" />
                            <Link text="Previous Experience" press="onNavEditPreviousExperience" />
                        </VBox>
                    </VBox>

                    <!-- Salary Category -->
                    <VBox class="hrmsCategoryBox">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://money-bills" size="2rem" color="#2ecc71" xmlns:core="sap.ui.core" />
                            <Title text="Salary" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <VBox class="hrmsLinkList">
                            <Link text="CTC" press="onNavSalaryCTC" />
                            <Link text="Payslip" press="onNavSalaryPayslip" />
                            <Link text="Monthly Report" press="onNavSalaryMonthlyReport" />
                        </VBox>
                    </VBox>

                    <!-- Taxation Category -->
                    <VBox class="hrmsCategoryBox">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://waiver" size="2rem" color="#f39c12" xmlns:core="sap.ui.core" />
                            <Title text="Taxation" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <VBox class="hrmsLinkList">
                            <Link text="View Tax Eligibility | Tax Projection |" />
                            <Link text="Download Tax Projection" />
                            <Link text="Download Form 16 | Declaration List |" />
                            <Link text="Edit Tax Eligibility" />
                            <Link text="Add Declaration |" />
                            <Link text="Submit Tax Declaration - Sheet |" />
                            <Link text="Investment / Claim Made List" />
                        </VBox>
                    </VBox>

                    <!-- Quick Info Category -->
                    <VBox class="hrmsCategoryBox">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://BusinessSuiteInAppSymbols/icon-quick-info" size="2rem" color="#9b59b6" xmlns:core="sap.ui.core" />
                            <Title text="Quick Info" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <VBox class="hrmsLinkList">
                            <Link text="Tax Calculator | Photo Gallery |" />
                            <Link text="Add Quick Links" />
                        </VBox>
                    </VBox>

                    <!-- Workflow Category -->
                    <VBox class="hrmsCategoryBox">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://workflow-tasks" size="2rem" color="#34495e" xmlns:core="sap.ui.core" />
                            <Title text="Workflow" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <VBox class="hrmsLinkList">
                            <Link text="My Approvers | My Workflow |" />
                            <Link text="Organization Chart" />
                            <Link text="ORG Chart Corporate View" />
                        </VBox>
                    </VBox>
                </layout:Grid>
            </VBox>
        </content>
    </Page>
</mvc:View>
