<mvc:View
    controllerName="com.viscap.hrms.controller.ChangePassword"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true">
    <Page title="Change Password" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <VBox class="sapUiMediumMargin">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <f:content>
                        <Label text="Old Password" required="true" />
                        <Input type="Password" />
                        
                        <Label text="New Password" required="true" />
                        <Input type="Password" />
                        
                        <Label text="Confirm New Password" required="true" />
                        <Input type="Password" />
                    </f:content>
                </f:SimpleForm>
                <HBox justifyContent="Center" class="sapUiMediumMarginTop">
                    <Button text="Update Password" type="Emphasized" press="onUpdatePassword" />
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
