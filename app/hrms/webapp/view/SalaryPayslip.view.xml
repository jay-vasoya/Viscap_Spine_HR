<mvc:View
    controllerName="com.viscap.hrms.controller.SalaryPayslip"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page title="Salary > Payslip" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <VBox class="sapUiMediumMargin">
                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                    <Label text="For The Period" class="sapUiSmallMarginEnd" />
                    <Select width="200px">
                        <items>
                            <core:Item text="--Select Period--" key="" />
                        </items>
                    </Select>
                </HBox>
                
                <Table noDataText="No details available" class="sapUiMediumMarginTop">
                    <columns>
                        <Column><Text text="Month" /></Column>
                        <Column><Text text="Year" /></Column>
                        <Column hAlign="End"><Text text="Gross Salary" /></Column>
                        <Column hAlign="End"><Text text="Net Salary" /></Column>
                        <Column><Text text="Paid On" /></Column>
                        <Column><Text text="Status" /></Column>
                        <Column hAlign="Center"><Text text="Download" /></Column>
                    </columns>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
