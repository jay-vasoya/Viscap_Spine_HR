<mvc:View
    controllerName="com.viscap.hrms.controller.ViewAssets"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page title="View > Assets List" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <VBox class="sapUiMediumMargin">
                <Table noDataText="No details available">
                    <columns>
                        <Column><Text text="Asset ID" /></Column>
                        <Column><Text text="Asset Name" /></Column>
                        <Column><Text text="Issue Date" /></Column>
                        <Column><Text text="Return Date" /></Column>
                        <Column><Text text="Condition" /></Column>
                    </columns>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
