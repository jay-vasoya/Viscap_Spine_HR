<mvc:View
    controllerName="com.viscap.hrms.controller.SalaryCTC"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true">
    <Page title="Salary > CTC" showNavButton="true" navButtonPress="onNavBack">
        <headerContent>
            <Button icon="sap-icon://print" />
        </headerContent>
        <content>
            <VBox class="sapUiMediumMargin">
                <Title text="VISCAP Consultancy Services Pvt Ltd" level="H3" textAlign="Center" class="sapUiLargeMarginBottom" width="100%" />
                
                <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" columnsL="2" columnsM="2">
                    <f:content>
                        <core:Title text="" />
                        <Label text="For Year" />
                        <Text text="2025 - 2026" />
                        
                        <Label text="Employee Code" />
                        <Text text="240" />
                        
                        <Label text="Joining Date" />
                        <Text text="January 1, 2026" />
                        
                        <Label text="Grade" />
                        <Text text="Intern" />
                        
                        <Label text="Department" />
                        <Text text="SAP BTP" />
                        
                        <core:Title text="" />
                        <Label text="Employee Name" />
                        <Text text="Jay Vasoya" />
                        
                        <Label text="Birth Date" />
                        <Text text="September 14, 2005" />
                        
                        <Label text="Branch" />
                        <Text text="Ahmedabad" />
                        
                        <Label text="Designation" />
                        <Text text="SAP BTP Intern" />
                    </f:content>
                </f:SimpleForm>

                <VBox class="sapUiMediumMarginTop">
                    <Title text="Outside Payroll Benefits" level="H4" class="sapUiSmallMarginBottom" />
                    <Table>
                        <columns>
                            <Column><Text text="Benefit Description" /></Column>
                            <Column hAlign="End"><Text text="Amount (INR)" /></Column>
                            <Column hAlign="End"><Text text="YTD (INR)" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="(C) Total Outside Payroll Benefits" />
                                    <Text text="0.00" />
                                    <Text text="0.00" />
                                </cells>
                            </ColumnListItem>
                            <ColumnListItem>
                                <cells>
                                    <Text text="(A+C) Cost To Company" />
                                    <Text text="0.00" />
                                    <Text text="0.00" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
