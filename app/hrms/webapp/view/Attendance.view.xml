<mvc:View
  controllerName="com.viscap.hrms.controller.Attendance"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout"
  displayBlock="true">

  <Page title="My Attendance" showNavButton="true" navButtonPress="onNavBack" backgroundDesign="List">

    <headerContent>
      <Select id="monthSelector" change="onMonthChange">
        <core:Item key="1"  text="January" />
        <core:Item key="2"  text="February" />
        <core:Item key="3"  text="March" />
        <core:Item key="4"  text="April" />
        <core:Item key="5"  text="May" />
        <core:Item key="6"  text="June" />
        <core:Item key="7"  text="July" />
        <core:Item key="8"  text="August" />
        <core:Item key="9"  text="September" />
        <core:Item key="10" text="October" />
        <core:Item key="11" text="November" />
        <core:Item key="12" text="December" />
      </Select>
      <Select id="yearSelector" change="onMonthChange">
        <core:Item key="2026" text="2026" />
        <core:Item key="2025" text="2025" />
      </Select>
    </headerContent>

    <content>
      <VBox class="sapUiMediumMargin">

        <!-- Summary Tiles -->
        <layout:Grid defaultSpan="XL2 L2 M4 S6" class="sapUiSmallMarginBottom">
          <layout:content>
            <GenericTile header="Present" class="hrmsTileSmall">
              <tileContent><TileContent><content>
                <NumericContent value="{attendModel>/present}" valueColor="Good" />
              </content></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="Absent" class="hrmsTileSmall">
              <tileContent><TileContent><content>
                <NumericContent value="{attendModel>/absent}" valueColor="Critical" />
              </content></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="Leave" class="hrmsTileSmall">
              <tileContent><TileContent><content>
                <NumericContent value="{attendModel>/leave}" valueColor="Neutral" />
              </content></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="Holidays" class="hrmsTileSmall">
              <tileContent><TileContent><content>
                <NumericContent value="{attendModel>/holidays}" valueColor="Good" />
              </content></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="Avg Hours" class="hrmsTileSmall">
              <tileContent><TileContent><content>
                <NumericContent value="{attendModel>/avgHours}" scale="hrs" valueColor="Good" />
              </content></TileContent></tileContent>
            </GenericTile>
          </layout:content>
        </layout:Grid>

        <!-- Attendance Table -->
        <Table
          id="attendTable"
          items="{
            path: 'hrms>/Attendances',
            filters: [{ path: 'employee_ID', operator: 'EQ', value1: 'e1000000-0000-0000-0000-000000000001' }],
            sorters: [{ path: 'date', descending: true }]
          }"
          backgroundDesign="Solid"
          growing="true"
          growingThreshold="31">

          <headerToolbar>
            <Toolbar>
              <Title text="Attendance Log" level="H4" />
              <ToolbarSpacer />
            </Toolbar>
          </headerToolbar>

          <columns>
            <Column width="9rem"><Text text="Date" /></Column>
            <Column width="6rem"><Text text="Day" /></Column>
            <Column width="7rem"><Text text="In Time" /></Column>
            <Column width="7rem"><Text text="Out Time" /></Column>
            <Column width="7rem"><Text text="Hours" /></Column>
            <Column width="8rem"><Text text="Status" /></Column>
            <Column><Text text="Remarks" /></Column>
          </columns>

          <items>
            <ColumnListItem>
              <cells>
                <Text text="{hrms>date}" />
                <Text text="{path: 'hrms>date', formatter: '.dayNameFormatter'}" />
                <Text text="{hrms>inTime}" />
                <Text text="{hrms>outTime}" />
                <ObjectNumber number="{hrms>workHours}" unit="h"
                  state="{= ${hrms>workHours} >= 8 ? 'Success' : ${hrms>workHours} > 0 ? 'Warning' : 'None'}" />
                <ObjectStatus text="{hrms>status}"
                  state="{= ${hrms>status} === 'Present' ? 'Success' :
                           ${hrms>status} === 'Absent'  ? 'Error'   :
                           ${hrms>status} === 'Leave'   ? 'Warning' : 'None'}" />
                <Text text="{hrms>remarks}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>

      </VBox>
    </content>

    <footer>
      <Bar>
        <contentLeft>
          <Button icon="sap-icon://home" text="Home" press="onNavBack" />
        </contentLeft>
        <contentRight>
          <Button icon="sap-icon://add" text="Apply Swipe" type="Emphasized" press="onApplySwipeNew" />
        </contentRight>
      </Bar>
    </footer>

  </Page>

  <!-- Swipe Dialog -->
  <Dialog id="swipeDialog" title="Apply Swipe Request" contentWidth="400px">
    <content>
      <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
        <Label text="Date" required="true" class="sapUiSmallMarginBottom" />
        <DatePicker id="swipeDatePicker" valueFormat="yyyy-MM-dd"
          displayFormat="dd MMM yyyy" width="100%" class="sapUiSmallMarginBottom" />

        <Label text="Swipe Time" required="true" class="sapUiSmallMarginBottom" />
        <TimePicker id="swipeTimePicker" valueFormat="HH:mm:ss"
          displayFormat="HH:mm" width="100%" class="sapUiSmallMarginBottom" />

        <Label text="Swipe Type" required="true" class="sapUiSmallMarginBottom" />
        <Select id="swipeTypeSelect" width="100%" class="sapUiSmallMarginBottom">
          <core:Item key="IN"  text="IN" />
          <core:Item key="OUT" text="OUT" />
        </Select>

        <Label text="Reason" required="true" class="sapUiSmallMarginBottom" />
        <TextArea id="swipeReasonInput" rows="3" width="100%" />
      </VBox>
    </content>
    <beginButton>
      <Button text="Submit" type="Emphasized" press="onSubmitSwipe" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press="onCloseSwipeDialog" />
    </endButton>
  </Dialog>

</mvc:View>
