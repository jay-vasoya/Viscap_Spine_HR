<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog id="editFamilyDialog" title="Edit > Family" contentWidth="600px">
        <content>
            <VBox class="sapUiContentPadding">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <f:content>
                        <Label text="Name" required="true" />
                        <Input />
                        
                        <Label text="Date of Birth" required="true" />
                        <DatePicker displayFormat="dd-MMM-yyyy" valueFormat="yyyy-MM-dd" />
                        
                        <Label text="Relation" required="true" />
                        <Select selectedKey="Father">
                            <items>
                                <core:Item text="Father" key="Father" />
                                <core:Item text="Mother" key="Mother" />
                                <core:Item text="Spouse" key="Spouse" />
                                <core:Item text="Child" key="Child" />
                                <core:Item text="Other" key="Other" />
                            </items>
                        </Select>
                        
                        <Label text="Occupation" required="true" />
                        <Input />
                        
                        <Label text="Age (In Years)" required="true" />
                        <Input editable="false" />
                        
                        <Label text="Contact No" required="true" />
                        <Input />
                        
                        <Label text="Emergency" required="true" />
                        <Select>
                            <items>
                                <core:Item text="Yes" key="Yes" />
                                <core:Item text="No" key="No" />
                            </items>
                        </Select>
                        
                        <Label text="Gender" required="true" />
                        <Select selectedKey="Male">
                            <items>
                                <core:Item text="Male" key="Male" />
                                <core:Item text="Female" key="Female" />
                                <core:Item text="Other" key="Other" />
                            </items>
                        </Select>
                        
                        <Label text="Aadhaar No" />
                        <Input />

                        <Label text="" />
                        <RadioButtonGroup columns="1">
                            <RadioButton text="Continue adding new entry" />
                            <RadioButton text="Back to list" selected="true" />
                        </RadioButtonGroup>
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onDialogUpdate" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onDialogCancel" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
