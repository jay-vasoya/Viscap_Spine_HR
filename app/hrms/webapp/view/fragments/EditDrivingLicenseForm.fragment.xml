<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog id="editDrivingLicenseDialog" title="Edit > Driving License" contentWidth="600px">
        <content>
            <VBox class="sapUiContentPadding">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <f:content>
                        <Label text="License For" />
                        <Select selectedKey="Self">
                            <items>
                                <core:Item text="Self" key="Self" />
                                <core:Item text="Family" key="Family" />
                            </items>
                        </Select>
                        
                        <Label text="License No." required="true" />
                        <Input />
                        
                        <Label text="Issue Date" />
                        <DatePicker displayFormat="dd-MMM-yyyy" valueFormat="yyyy-MM-dd" />
                        
                        <Label text="Expiry Date" />
                        <DatePicker displayFormat="dd-MMM-yyyy" valueFormat="yyyy-MM-dd" />
                        
                        <Label text="Two Wheeler" />
                        <CheckBox />
                        
                        <Label text="Three Wheeler" />
                        <CheckBox />
                        
                        <Label text="Four Wheeler" />
                        <CheckBox />
                        
                        <Label text="Vehicle Details" />
                        <Input />
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </content>
        <beginButton>
            <Button text="Update" type="Emphasized" press="onDialogUpdate" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onDialogCancel" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
