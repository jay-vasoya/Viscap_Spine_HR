<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.ui.unified">
    <Dialog id="editVisaDialog" title="Edit > Visa Details" contentWidth="600px">
        <content>
            <VBox class="sapUiContentPadding">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <f:content>
                        <Label text="Visa For" />
                        <Select selectedKey="Self">
                            <items>
                                <core:Item text="Self" key="Self" />
                                <core:Item text="Spouse" key="Spouse" />
                                <core:Item text="Child" key="Child" />
                            </items>
                        </Select>
                        
                        <Label text="Visa Name" required="true" />
                        <Input />
                        
                        <Label text="Visa No." />
                        <Input />
                        
                        <Label text="Citizenship" />
                        <Input />
                        
                        <Label text="Visa Issue Date" />
                        <DatePicker displayFormat="dd-MMM-yyyy" valueFormat="yyyy-MM-dd" />
                        
                        <Label text="Visa Expiry Date" />
                        <DatePicker displayFormat="dd-MMM-yyyy" valueFormat="yyyy-MM-dd" />
                        
                        <Label text="Work Permit" />
                        <Input />
                        
                        <Label text="Visa Document" />
                        <u:FileUploader
                            name="myFileUpload"
                            uploadUrl="upload/"
                            tooltip="Upload your visa document"
                            buttonText="Choose File"
                            placeholder="No file chosen" />

                        <Label text="Remark" />
                        <TextArea rows="3" width="100%" />

                        <Label text="" />
                        <RadioButtonGroup columns="2">
                            <RadioButton text="Continue adding new entry" />
                            <RadioButton text="Back to list" selected="true" />
                        </RadioButtonGroup>
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onDialogUpdate" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onDialogCancel" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
