<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog id="editSkillsDialog" title="Edit > Skills" contentWidth="500px">
        <content>
            <VBox class="sapUiContentPadding">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <f:content>
                        <Label text="Skill" />
                        <Select selectedKey="Accounts">
                            <items>
                                <core:Item text="Accounts" key="Accounts" />
                                <core:Item text="Technical" key="Technical" />
                                <core:Item text="Communication" key="Communication" />
                            </items>
                        </Select>
                        
                        <Label text="Experience (years)" />
                        <VBox>
                            <Input placeholder="eg.. 1.01 or 1.10" />
                            <Text text="eg.. 1.01 or 1.10" class="sapUiTinyMarginTop" />
                        </VBox>
                        
                        <Label text="Competency" />
                        <Select>
                            <items>
                                <core:Item text="Beginner" key="Beginner" />
                                <core:Item text="Intermediate" key="Intermediate" />
                                <core:Item text="Expert" key="Expert" />
                            </items>
                        </Select>

                        <Label text="" />
                        <RadioButtonGroup columns="1">
                            <RadioButton text="Continue adding new entry" />
                            <RadioButton text="Back to list" selected="true" />
                        </RadioButtonGroup>
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onDialogUpdate" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onDialogCancel" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
