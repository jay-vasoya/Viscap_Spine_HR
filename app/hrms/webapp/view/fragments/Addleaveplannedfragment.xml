<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog id="addPlannedDialog" title="Add Leave Planned" contentWidth="440px">
    <content>
      <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

        <Label text="Leave Type" required="true" class="sapUiTinyMarginBottom" />
        <Select id="plannedTypeSelect" width="100%" class="sapUiSmallMarginBottom"
          items="{path: 'hrms>/LeaveTypes'}">
          <core:Item key="{hrms>ID}" text="{hrms>name}" />
        </Select>

        <Label text="From Date" required="true" class="sapUiTinyMarginBottom" />
        <DatePicker id="plannedFromDate" valueFormat="yyyy-MM-dd"
          displayFormat="dd MMM yyyy" width="100%"
          class="sapUiSmallMarginBottom" change="onPlannedDateChange" />

        <Label text="To Date" required="true" class="sapUiTinyMarginBottom" />
        <DatePicker id="plannedToDate" valueFormat="yyyy-MM-dd"
          displayFormat="dd MMM yyyy" width="100%"
          class="sapUiSmallMarginBottom" change="onPlannedDateChange" />

        <Label text="Working Days" class="sapUiTinyMarginBottom" />
        <Input id="plannedDays" value="{plannedModel>/days}"
               enabled="false" width="100%" class="sapUiSmallMarginBottom" />

        <Label text="Reason" required="true" class="sapUiTinyMarginBottom" />
        <TextArea id="plannedReason" rows="3" width="100%"
                  placeholder="Enter reason..." />
      </VBox>
    </content>
    <beginButton>
      <Button text="Save" type="Emphasized" press="onSavePlanned" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press="onClosePlannedDialog" />
    </endButton>
  </Dialog>

</core:FragmentDefinition>