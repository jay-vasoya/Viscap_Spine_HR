<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog id="applyODDialog" title="Apply Outdoor Duty" contentWidth="440px">
    <content>
      <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

        <Label text="Date" required="true" class="sapUiTinyMarginBottom" />
        <DatePicker id="odDatePicker" valueFormat="yyyy-MM-dd"
          displayFormat="dd MMM yyyy" width="100%"
          class="sapUiSmallMarginBottom" />

        <Label text="From Time" required="true" class="sapUiTinyMarginBottom" />
        <TimePicker id="odFromTime" valueFormat="HH:mm" displayFormat="HH:mm"
          width="100%" class="sapUiSmallMarginBottom" />

        <Label text="To Time" required="true" class="sapUiTinyMarginBottom" />
        <TimePicker id="odToTime" valueFormat="HH:mm" displayFormat="HH:mm"
          width="100%" class="sapUiSmallMarginBottom" />

        <Label text="Location" required="true" class="sapUiTinyMarginBottom" />
        <Input id="odLocation" width="100%" placeholder="Enter location..."
               class="sapUiSmallMarginBottom" />

        <Label text="Purpose" required="true" class="sapUiTinyMarginBottom" />
        <TextArea id="odPurpose" rows="3" width="100%"
                  placeholder="Enter purpose of outdoor duty..." />
      </VBox>
    </content>
    <beginButton>
      <Button text="Submit" type="Emphasized" press="onSubmitOD" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press="onCloseODDialog" />
    </endButton>
  </Dialog>

</core:FragmentDefinition>