<mvc:View
    controllerName="com.viscap.hrms.controller.EditLanguages"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page title="Edit > Languages" showNavButton="true" navButtonPress="onNavBack">
        <headerContent>
            <HBox alignItems="Center">
                <Label text="Module" class="sapUiTinyMarginEnd" />
                <Select selectedKey="Languages" class="sapUiMediumMarginEnd" width="150px">
                    <items>
                        <core:Item text="Languages" key="Languages" />
                    </items>
                </Select>
                <Label text="View Status" class="sapUiTinyMarginEnd" />
                <Select change="onStatusChange" width="150px">
                    <items>
                        <core:Item text="Pending" key="Pending" />
                        <core:Item text="Accepted" key="Accepted" />
                        <core:Item text="Rejected" key="Rejected" />
                        <core:Item text="All" key="All" />
                    </items>
                </Select>
            </HBox>
        </headerContent>
        <content>
            <VBox class="sapUiMediumMargin">
                <HBox>
                    <Button text="Add New" type="Accept" icon="sap-icon://add" press="onAddNew" class="sapUiTinyMarginEnd" />
                    <Button text="Delete" type="Reject" icon="sap-icon://delete" />
                </HBox>
                
                <Table noDataText="No details available" class="sapUiMediumMarginTop">
                    <columns>
                        <Column><Text text="Request Type" /></Column>
                        <Column><Text text="Status" /></Column>
                        <Column><Text text="Created Date" /></Column>
                    </columns>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
