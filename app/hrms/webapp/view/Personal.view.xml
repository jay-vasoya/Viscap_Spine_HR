<mvc:View
    controllerName="com.viscap.hrms.controller.Personal"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true">
    <Page title="View > Personal" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <VBox class="sapUiMediumMargin">
                <Title text="Personal Details" level="H2" textAlign="Center" width="100%" class="sapUiMediumMarginBottom" />

                <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="3" labelSpanM="3" emptySpanL="0" emptySpanM="0" columnsL="2" columnsM="2">
                    <f:content>
                        <Label text="Birth Place" />
                        <Text text="{user>/birthPlace}" />
                        
                        <Label text="Nationality" />
                        <Text text="{user>/nationality}" />
                        
                        <Label text="Religion" />
                        <Text text="{user>/religion}" />
                        
                        <Label text="Caste" />
                        <Text text="{user>/caste}" />
                        
                        <Label text="Blood Group" />
                        <Text text="{user>/bloodGroup}" />
                        
                        <Label text="Height" />
                        <Text text="{user>/height}" />
                        
                        <Label text="Weight" />
                        <Text text="{user>/weight}" />
                        
                        <Label text="Marital Status" />
                        <Text text="{user>/maritalStatus}" />
                        
                        <Label text="Identification Mark" />
                        <Text text="{user>/identificationMark}" />
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </content>
    </Page>
</mvc:View>
